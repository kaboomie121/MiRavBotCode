@model DashboardViewModel
@{
    ViewData["Title"] = $"{Model.SelectedGuild?.Name ?? "Select a Server"}";
}

<!-- Removed restricted column classes like col-md-9 here -->
<div class="pt-3 pb-2 mb-3">
    <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-3">
        <h1 class="h2">@(Model.SelectedGuild?.Name ?? "Select a Server")</h1>
        
        <div class="dropdown">
            <button class="btn btn-secondary dropdown-toggle d-flex align-items-center" type="button" data-bs-toggle="dropdown">
                @if (Model.SelectedGuild != null)
                {
                    <img src="@Model.SelectedGuild.IconUrl" width="24" height="24" class="rounded-circle me-2" alt="icon"/>
                    @Model.SelectedGuild.Name
                }
                else
                {
                    <span>Choose Server</span>
                }
            </button>
            <ul class="dropdown-menu">
                @foreach (var guild in Model.UserGuilds)
                {
                    <li>
                        <a class="dropdown-item d-flex justify-content-between align-items-center" href="?guildId=@guild.Id">
                            <img src="@guild.IconUrl" width="20" class="rounded-circle me-1" />
                            @guild.Name
                            @{
                                if (!guild.IsBotPresent)
                                {
                                    <span class="badge bg-secondary ms-2" style="font-size: 0.65rem;">Not Added</span>
                                }
                                else
                                {
                                    <span class="badge bg-success ms-2" style="font-size: 0.65rem;">Bot Present</span>
                                }
                            }
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>

    @if (Model.SelectedGuild != null)
    {
        if (Model.SelectedGuild.IsBotPresent)
        {
            <div class="row">
                <div class="col-md-4">
                    <div class="list-group">
                        <a href="#general-settings" class="list-group-item list-group-item-action">General Settings</a>
                        <a href="#auto-mod" class="list-group-item list-group-item-action">Auto-Mod</a>
                        <a href="#logging" class="list-group-item list-group-item-action">Logging</a>
                    </div>
                </div>
                <div class="col-md-8">
                    <div class="card p-3">
                        <h3 id="general-settings">General Settings for @Model.SelectedGuild.Name</h3>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-person-plus" style="font-size: 4rem; color: #ccc;"></i>
                <h3 class="mt-3">Bot not in @Model.SelectedGuild.Name</h3>
                <p class="text-muted">The bot needs to be added to this server before you can manage its settings.</p>
                <a id="inviteBotBtn" href="https://discord.com/oauth2/authorize?client_id=@Model.ClientId&permissions=8&integration_type=0&scope=bot+applications.commands&guild_id=@Model.SelectedGuild.Id" target="_blank" class="btn btn-primary mt-3 px-4">
                    Invite Bot to Server
                </a>
            </div>
        }
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-robot" style="font-size: 4rem; color: #ccc;"></i>
            <h3 class="mt-3">Welcome to the Bot Manager</h3>
            <p class="text-muted">Please select a server from the dropdown above to manage its settings.</p>
        </div>
    }
</div>

<!-- Add this script to handle returning from the Discord Auth tab -->
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const inviteBtn = document.getElementById("inviteBotBtn");
        if (inviteBtn) {
            inviteBtn.addEventListener("click", function () {
                // When the user clicks the invite button, wait for them to return to this window
                window.addEventListener("focus", function onFocus() {
                    // Remove listener to prevent multiple reloads
                    window.removeEventListener("focus", onFocus);
                    
                    // Optional: Give Discord a brief moment to update before reloading
                    setTimeout(function() {
                        window.location.reload();
                    }, 500); 
                });
            });
        }
    });
</script>